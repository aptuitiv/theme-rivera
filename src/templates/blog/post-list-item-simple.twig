{% import 'macros/macros' as macros %}

<h2><a href="{{ post.url }}" class="link-subtle">{{ post.postTitle }}</a></h2>
<div class="flex align-center mb-1">{{ macros.iconAriaHidden('calendar') }} <span>&nbsp;{{ post.publishedOnDate }}</span></div>
{% if post.abstract %}
    {{ post.abstract|striptags }}
{% else %}
    {{ post.content|striptags|truncate(400) }}
{% endif %}
<div><a href=" {{ post.url }}" class="inline-flex align-center">Read more {{ macros.iconAriaHidden("chevron-thin-right") }}</a></div>
